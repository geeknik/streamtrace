# StreamTrace environment variables
#
# Copy this file to .env and adjust for your environment:
#   cp .env.example .env
#
# NEVER commit .env to version control. It is in .gitignore.
#
# These variables are read by Docker Compose and by the StreamTrace binary.
# In production, use a secret manager rather than a .env file.

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------

# [REQUIRED] Password for the PostgreSQL/TimescaleDB database.
# Used by both Docker Compose (to create the database user) and the
# application (to connect).
#
# In production: use a strong, randomly generated password (32+ characters).
# In development: the default below is fine for local use.
#
# Security: this value is passed to the database container at startup.
# Changing it after initial setup requires resetting the database volume
# (docker compose down -v && docker compose up).
POSTGRES_PASSWORD=streamtrace_dev

# [REQUIRED] Full PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
#
# For Docker Compose: use the service name "timescaledb" as host.
# For local development (database in Docker, app on host): use "localhost".
# For production: point to your managed TimescaleDB instance.
#
# The password here must match POSTGRES_PASSWORD above.
# TLS: append ?sslmode=require for production connections.
DATABASE_URL=postgresql://streamtrace:streamtrace_dev@localhost:5432/streamtrace

# ---------------------------------------------------------------------------
# APPLICATION
# ---------------------------------------------------------------------------

# [REQUIRED] Runtime environment. One of: development, staging, production
#
# Effects:
#   development -- verbose logging, relaxed rate limits, dev CORS origins
#   staging     -- production-like settings with debug endpoints enabled
#   production  -- strict security, JSON logging, no debug endpoints
ST_ENV=development

# [OPTIONAL] Rust log level filter. Overrides config/default.toml [logging] level.
# Format: <default_level>,<crate>=<level>,...
#
# Examples:
#   RUST_LOG=debug                       -- debug for everything
#   RUST_LOG=info                        -- info for everything
#   RUST_LOG=info,st_store=debug         -- info default, debug for database queries
#   RUST_LOG=warn,st_api=info            -- quiet except API request logging
#
# In production: use "info" or "warn". Never use "debug" or "trace" in
# production -- they may log sensitive request data.
RUST_LOG=debug

# ---------------------------------------------------------------------------
# SIGNING
# ---------------------------------------------------------------------------

# Ed25519 signing key for evidence bundles (hex-encoded, 64 characters = 32 bytes).
# If not set, an ephemeral key is generated on each startup.
# WARNING: Evidence bundles signed with an ephemeral key cannot be verified after restart.
# Generate with: openssl rand -hex 32
# ST_SIGNING_KEY_HEX=

# ---------------------------------------------------------------------------
# OPTIONAL OVERRIDES
# ---------------------------------------------------------------------------

# Server bind address. Overrides config/default.toml [server] host.
# Uncomment to change from the default "0.0.0.0".
# ST_SERVER_HOST=127.0.0.1

# Server port. Overrides config/default.toml [server] port.
# Uncomment to change from the default 8080.
# ST_SERVER_PORT=8080

# Rate limit (requests per second per API key).
# Overrides config/default.toml [security] rate_limit_per_second.
# ST_RATE_LIMIT=100

# Maximum request body size in bytes.
# Overrides config/default.toml [server] request_body_limit_bytes.
# ST_REQUEST_BODY_LIMIT=10485760
